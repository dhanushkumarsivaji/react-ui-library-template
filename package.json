{
  "name": "react-ui-library-template",
  "version": "1.0.0",
  "description": "Production-ready React UI component library template with TypeScript, Storybook 10, Jest 30, ESLint 10 flat config, accessibility testing, changesets, and CI/CD — the most comprehensive open-source starter for building design systems",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "keywords": [
    "react",
    "react-component-library",
    "react-ui-library",
    "react19",
    "component-library",
    "ui-library",
    "ui-kit",
    "design-system",
    "design-tokens",
    "dark-mode",
    "theming",
    "typescript",
    "storybook",
    "storybook-10",
    "atomic-design",
    "react-components",
    "template",
    "boilerplate",
    "starter",
    "starter-kit",
    "scaffold",
    "accessibility",
    "a11y",
    "wcag",
    "jest-axe",
    "testing",
    "jest",
    "snapshot-testing",
    "unit-testing",
    "rollup",
    "tree-shaking",
    "mui",
    "material-ui",
    "changesets",
    "conventional-commits",
    "ci-cd",
    "github-actions",
    "eslint-flat-config",
    "eslint10",
    "prettier",
    "husky",
    "commitlint",
    "npm-provenance",
    "supply-chain-security",
    "ai-governance",
    "claude-code",
    "copilot",
    "cursor",
    "component-generator"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "bugs": {
    "url": ""
  },
  "scripts": {
    "start": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "rollup -c && tsc --emitDeclarationOnly",
    "build:watch": "rollup -c --watch",
    "build-storybook": "storybook build -o storybook-static",
    "analyze": "ANALYZE=true rollup -c",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "test:update": "jest -u",
    "coverage": "jest --coverage",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint:check && npm run prettier:check && npm run typecheck && npm run test -- --coverage && npm run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "npm run build && changeset publish",
    "release": "npm run changeset:version",
    "commit": "git-cz",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "size": "size-limit",
    "generate": "bash scripts/generate-component.sh"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.30.0",
    "@changesets/changelog-github": "^0.6.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.1",
    "@storybook/react": "^10.3.3",
    "@storybook/react-webpack5": "^10.3.3",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.60.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.98.0",
    "size-limit": "^12.0.1",
    "storybook": "^10.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "size-limit": [
    {
      "path": "dist/esm/index.js",
      "limit": "50 kB"
    }
  ]
}
